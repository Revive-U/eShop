<!DOCTYPE html>
<html>

<head>
	<meta charset="utf-8">
	<meta http-equiv="Content-Script-Type" content="text/javascript">
	<meta http-equiv="Content-Style-Type" content="text/css">
	<title>Pretendo eShop</title>
	<link rel="stylesheet" href="/css/minified/index.css">
</head>

<body>
	<h1>Welcome!</h1>
	<h2>This is the ReviveShop U eShop testing environment</h2>

	<script type="text/javascript" src="/js/grove.js"
		onerror="wiiuErrorViewer.openByCode(1119000);wiiuBrowser.jumpToHomeButtonMenu()"></script>
	<script lang="javascript">
		Grove.init();
	</script>

	<button onclick="location.reload(); wiiuSound.playSoundByName('SE_WOOD_OK',1);">Refresh</button>
	<br>
	<a href="/news"><button onclick="wiiuSound.playSoundByName('SE_WOOD_OPEN_MENU',1);">News</button></a>
	<br>
	<a href="/debug" onclick="wiiuSound.playSoundByName('SE_WOOD_OPEN_MENU',1);"><button>Debug Menu</button></a>
	<br>
	<a href="/install" onclick="wiiuSound.playSoundByName('SE_WOOD_OPEN_MENU',1);"><button>Install Apps</button></a>
	<br>
	<a href="/random" onclick="wiiuSound.playSoundByName('SE_WOOD_OPEN_MENU',1);"><button>Random</button></a>
	<br>
	<button onclick="Grove.closeShop();">Close</button>

	<style>
		button {
			width: 250px;
			height: 100px;
			font-size: 25px;
		}

		.poll {
			width: 450px;
			height: 100px;
			font-size: 25px;
		}
	</style>
</body>

</html>